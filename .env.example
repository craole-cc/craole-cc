# shellcheck disable=SC2034

#╔═══════════════════════════════════════════════════════════╗
#║ Database                                                  ║
#╚═══════════════════════════════════════════════════════════╝
DATABASE_URL=sqlite://./database/data/portfolio.db

# Uncomment after running `cargo sqlx prepare --workspace` to allow
# building without a live database connection (useful for CI).
SQLX_OFFLINE=true
