  "query": "SELECT\n  p.id,\n  p.title,\n  p.slug,\n  p.description,\n  p.status,\n  p.repo_url,\n  p.live_url,\n  p.featured,\n  p.sort_order,\n  p.created_at,\n  (\n    SELECT COALESCE(GROUP_CONCAT(pt.tag, ','), '') || ''\n    FROM project_tags pt\n    WHERE pt.project_id = p.id\n  ) AS tags\n\nFROM projects p\nWHERE p.published = 1\n  AND p.id IN (SELECT project_id FROM project_tags WHERE tag = $1)\nORDER BY p.sort_order ASC, p.created_at DESC\n",
