{
  "fileinator.ignoredFolders": [
    "target",
    ".git",
    "app/src/pages/temp",
    "app/src/constants/icons copy.rs",
    "app/src/constants/icons/icons_old.rs",
    "style/tailwind.config.js"
  ],
  "emmet.includeLanguages": {
    "rust": "html",
    "*.rs": "html"
  },
  "tailwindCSS.includeLanguages": {
    "rust": "html",
    "*.rs": "html"
  },
  "files.associations": {
    "*.rs": "rust"
  },
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": true
  },
  "css.validate": false,
  "files.exclude": {
    "**/$RECYCLE.BIN": false,
    "**/*.lock": false,
    "**/*lock.*": false,
    "**/.DS_Store": false,
    "**/.admin": false,
    "**/.bin": false,
    "**/.direnv": false,
    "**/.editorconfig": false,
    "**/.env*": false,
    "**/.git": false,
    "**/node_modules": false,
    "**/.gitattributes": false,
    "**/.gitmodules": false,
    "**/mise.toml": false,
    "**/.mise.toml": false,
    "**/.github": false,
    "**/.gitignore": false,
    "**/.ignore": false,
    "**/.helix": false,
    "**/.hg": false,
    "**/.jj": false,
    "**/.justfile": false,
    "**/.rust*": false,
    "**/.shellcheckrc": false,
    "**/.svn": false,
    "**/askama.toml": false,
    "**/.clippy.toml": false,
    "**/clippy.toml": false,
    "**/.treefmt.toml": false,
    "**/.typos.toml": false,
    "**/.vscode": false,
    "**/CODE_OF_CONDUCT": false,
    "**/CODE_OF_CONDUCT.md": false,
    "**/CONTRIBUTING": false,
    "**/CONTRIBUTING.md": false,
    "**/LICENSE": false,
    "**/LICENSE-*": false,
    "**/Downloads": false,
    "**/LICENSE.md": false,
    "**/README": false,
    "**/README.md": false,
    "**/SECURITY": false,
    "**/SECURITY.md": false,
    "**/System Volume Information": false,
    "**/Thumbs.db": false,
    "**/archive": false,
    "**/deno.json": false,
    "**/deno.jsonc": false,
    "**/justfile": false,
    "**/review": false,
    "**/Review": false,
    "**/rust-analyzer.toml": false,
    "**/rust-toolchain*": false,
    "**/rust-toolchain.toml": false,
    "**/rustfmt.toml": false,
    "**/leptosfmt.toml": false,
    "**/trunk.toml": false,
    "**/*.bac": false,
    "**/target": false,
    "**/treefmt.toml": false
  },
}
