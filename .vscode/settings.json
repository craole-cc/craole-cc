{
  "fileinator.ignoredFolders": [
    "target",
    ".git",
    "app/src/pages/temp",
    "app/src/constants/icons copy.rs",
    "app/src/constants/icons/icons_old.rs",
    "style/tailwind.config.js"
  ],
  "emmet.includeLanguages": {
    "rust": "html",
    "*.rs": "html"
  },
  "tailwindCSS.includeLanguages": {
    "rust": "html",
    "*.rs": "html"
  },
  "files.associations": {
    "*.rs": "rust"
  },
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": true
  },
  "css.validate": false,
  "files.exclude": {
    "**/$RECYCLE.BIN": true,
    "**/*.lock": true,
    "**/*lock.*": true,
    "**/.DS_Store": true,
    "**/.admin": true,
    "**/.bin": true,
    "**/.direnv": true,
    "**/.editorconfig": true,
    "**/.env*": true,
    "**/.git": true,
    "**/node_modules": true,
    "**/.gitattributes": true,
    "**/.gitmodules": true,
    "**/mise.toml": true,
    "**/.mise.toml": true,
    "**/.github": true,
    "**/.gitignore": true,
    "**/.ignore": true,
    "**/.helix": true,
    "**/.hg": true,
    "**/.jj": true,
    "**/.justfile": true,
    "**/.rust*": true,
    "**/.shellcheckrc": true,
    "**/.svn": true,
    "**/askama.toml": true,
    "**/.clippy.toml": true,
    "**/clippy.toml": true,
    "**/.treefmt.toml": true,
    "**/.typos.toml": true,
    "**/.vscode": true,
    "**/CODE_OF_CONDUCT": true,
    "**/CODE_OF_CONDUCT.md": true,
    "**/CONTRIBUTING": true,
    "**/CONTRIBUTING.md": true,
    "**/LICENSE": true,
    "**/LICENSE-*": true,
    "**/Downloads": true,
    "**/LICENSE.md": true,
    "**/README": true,
    "**/README.md": true,
    "**/SECURITY": true,
    "**/SECURITY.md": true,
    "**/System Volume Information": true,
    "**/Thumbs.db": true,
    "**/archive": true,
    "**/deno.json": true,
    "**/deno.jsonc": true,
    "**/justfile": true,
    "**/review": true,
    "**/Review": true,
    "**/rust-analyzer.toml": true,
    "**/rust-toolchain*": true,
    "**/rust-toolchain.toml": true,
    "**/rustfmt.toml": true,
    "**/leptosfmt.toml": true,
    "**/trunk.toml": true,
    "**/*.bac": true,
    "**/target": true,
    "**/treefmt.toml": true
  },
}
