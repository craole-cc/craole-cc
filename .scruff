[sqruff]
dialect = sqlite
max_line_length = 120

#~@ Indentation
indent_unit = space
tab_space_size = 4

#~@ Capitalisation
capitalisation_policy = upper
function_capitalisation_policy = upper
literal_capitalisation_policy = upper

#~@ Aliasing — enforce explicit AS (AL03 was firing in your seed file)
aliasing = explicit

# Trailing newline (LT12 was firing in get_tags.sql)
# These are enforced by default; listed here for visibility

# Rules to ignore project-wide
# (migration long-lines are handled via treefmt excludes instead)
